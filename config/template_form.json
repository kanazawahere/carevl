{
  "version": "1.0.0",
  "packages": [
    {
      "id": "nct",
      "label": "Người cao tuổi (≥ 60 tuổi)",
      "icon": "🧓",
      "sections": [
        {
          "id": "demographics",
          "label": "Thông tin cá nhân",
          "fields": [
            { "id": "ho_ten",        "label": "Họ và tên",              "type": "text",   "required": true },
            { "id": "ngay_sinh",     "label": "Ngày sinh",              "type": "date",   "required": true },
            { "id": "gioi_tinh",     "label": "Giới tính",              "type": "select", "required": true, "options": ["Nam", "Nữ"] },
            { "id": "ma_dinh_danh", "label": "Số định danh / BHYT",    "type": "text",   "required": true },
            { "id": "dia_chi",      "label": "Địa chỉ thường trú",     "type": "text",   "required": false }
          ]
        },
        {
          "id": "clinical",
          "label": "Khám lâm sàng",
          "fields": [
            { "id": "huyet_ap_tam_thu",   "label": "Huyết áp tâm thu (mmHg)",  "type": "number", "required": true, "validation": { "min": 50, "max": 300 } },
            { "id": "huyet_ap_tam_truong","label": "Huyết áp tâm trương (mmHg)","type": "number","required": true, "validation": { "min": 30, "max": 200 } },
            { "id": "nhip_tim",     "label": "Nhịp tim (lần/phút)",    "type": "number", "required": false, "validation": { "min": 30, "max": 200 } },
            { "id": "can_nang",     "label": "Cân nặng (kg)",          "type": "number", "required": false, "validation": { "min": 20, "max": 150 } },
            { "id": "chieu_cao",    "label": "Chiều cao (cm)",         "type": "number", "required": false, "validation": { "min": 100, "max": 220 } },
            { "id": "bmi",          "label": "BMI (tự tính)",          "type": "computed", "required": false, "formula": "can_nang / (chieu_cao/100)^2" },
            { "id": "tien_su_benh","label": "Tiền sử bệnh",           "type": "textarea","required": false },
            { "id": "ghi_chu_ls",   "label": "Ghi chú lâm sàng",       "type": "textarea","required": false }
          ]
        },
        {
          "id": "laboratory",
          "label": "Xét nghiệm (Sàng lọc NCD)",
          "fields": [
            { "id": "duong_huyet_doi",  "label": "Đường huyết đói (mmol/L)",  "type": "number","required": false, "validation": { "min": 1, "max": 30 } },
            { "id": "cholesterol",      "label": "Cholesterol (mmol/L)",      "type": "number","required": false, "validation": { "min": 1, "max": 15 } },
            { "id": "nuoc_tieu",        "label": "Nước tiểu",                "type": "select","required": false, "options": ["Bình thường", "Bất thường", "Chưa thực hiện"] }
          ]
        },
        {
          "id": "conclusion",
          "label": "Kết luận",
          "fields": [
            { "id": "phan_loai_sk", "label": "Phân loại sức khỏe",     "type": "select", "required": true, "options": ["Loại I", "Loại II", "Loại III", "Loại IV"] },
            { "id": "ket_luan",     "label": "Kết luận của bác sĩ",    "type": "textarea","required": true },
            { "id": "bac_si",       "label": "Bác sĩ phụ trách",       "type": "text",   "required": true },
            { "id": "ngay_kham",    "label": "Ngày khám",              "type": "date",   "required": true }
          ]
        }
      ]
    },
    {
      "id": "hs",
      "label": "Học sinh (Mầm non – Phổ thông)",
      "icon": "🎒",
      "sections": [
        {
          "id": "demographics",
          "label": "Thông tin cá nhân",
          "fields": [
            { "id": "ho_ten",        "label": "Họ và tên",              "type": "text",   "required": true },
