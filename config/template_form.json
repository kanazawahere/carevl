            { "id": "gioi_tinh",     "label": "Giới tính",              "type": "select", "required": true, "options": ["Nam", "Nữ"] },
            { "id": "ma_dinh_danh", "label": "Số định danh / BHYT",    "type": "text",   "required": true },
            { "id": "truong",        "label": "Trường học",             "type": "text",   "required": false },
            { "id": "lop",           "label": "Lớp",                    "type": "text",   "required": false }
          ]
        },
        {
          "id": "clinical",
          "label": "Khám lâm sàng",
          "fields": [
            { "id": "can_nang",     "label": "Cân nặng (kg)",          "type": "number", "required": true, "validation": { "min": 5, "max": 120 } },
            { "id": "chieu_cao",    "label": "Chiều cao (cm)",         "type": "number", "required": true, "validation": { "min": 70, "max": 200 } },
            { "id": "bmi",          "label": "BMI (tự tính)",          "type": "computed", "required": false, "formula": "can_nang / (chieu_cao/100)^2" },
            { "id": "thi_luc_p",    "label": "Thị lực mắt phải",      "type": "text",   "required": false },
            { "id": "thi_luc_t",    "label": "Thị lực mắt trái",      "type": "text",   "required": false },
            { "id": "rang_mieng",   "label": "Răng miệng",             "type": "select", "required": false, "options": ["Bình thường", "Sâu răng", "Viêm lợi", "Khác"] },
            { "id": "cot_song",     "label": "Cột sống",               "type": "select", "required": false, "options": ["Bình thường", "Cong vẹo", "Cần theo dõi"] }
          ]
        },
        {
          "id": "conclusion",
          "label": "Kết luận",
          "fields": [
            { "id": "phan_loai_sk", "label": "Phân loại sức khỏe",     "type": "select", "required": true, "options": ["Loại I", "Loại II", "Loại III", "Loại IV"] },
            { "id": "ket_luan",     "label": "Kết luận của bác sĩ",    "type": "textarea","required": true },
            { "id": "bac_si",       "label": "Bác sĩ phụ trách",       "type": "text",   "required": true },
            { "id": "ngay_kham",    "label": "Ngày khám",              "type": "date",   "required": true }
          ]
        }
      ]
    },
